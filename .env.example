# EventHub Configuration Example

# Copy this file to .env and modify the values as needed

# RabbitMQ Queue Names
EVENT_UPDATED_QUEUE=event.updated

# Service Ports
EVENTS_SERVICE_PORT=8081
NOTIFICATIONS_SERVICE_PORT=8082
TICKETING_SERVICE_PORT=8083

# RabbitMQ Credentials (for RabbitMQ container)
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# RabbitMQ Credentials (for Spring applications)
RABBITMQ_USER=guest
RABBITMQ_PASS=guest