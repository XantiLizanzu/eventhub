# RabbitMQ Queue Names
EVENT_UPDATED_QUEUE=event.updated

# Service Ports
EVENTS_SERVICE_PORT=8080
NOTIFICATIONS_SERVICE_PORT=8080
TICKETING_SERVICE_PORT=8080
PAYMENTS_SERVICE_PORT=8080
USERS_SERVICE_PORT=8080

# Service Hosts
EVENTS_SERVICE_HOST=events-service
NOTIFICATIONS_SERVICE_HOST=notifications-service
TICKETING_SERVICE_HOST=ticketing-service
PAYMENTS_SERVICE_HOST=payments-service
USERS_SERVICE_HOST=users-service

# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Database Configuration (for events-service)
DB_URL=jdbc:h2:mem:eventdb
DB_DRIVER=org.h2.Driver
DB_USERNAME=sa
DB_PASSWORD=

# H2 Console Configuration
H2_CONSOLE_ENABLED=true
H2_CONSOLE_PATH=/h2-console

# JPA Configuration
JPA_SHOW_SQL=true
JPA_DDL_AUTO=update
JPA_FORMAT_SQL=true

